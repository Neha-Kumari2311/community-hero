# OpenRouter API Key (powers all AI features - image analysis, quiz, insights)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# MongoDB Connection String
# For local: mongodb://localhost:27017/community-hero
# For Atlas: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/community-hero
MONGODB_URI=mongodb://localhost:27017/community-hero

# NextAuth Configuration
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Cloudinary (Image Upload)
# Get yours at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
